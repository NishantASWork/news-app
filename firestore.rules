rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: read/write own document only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // User bookmarks subcollection
    match /users/{userId}/bookmarks/{articleId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Articles: read for all, write for authenticated (admin check can be added via custom claims)
    match /articles/{articleId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    // Categories: read for all, write for authenticated
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
